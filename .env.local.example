# Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face TTS Configuration (OPTIONAL - works without API key)
# Get your API key from: https://huggingface.co/settings/tokens
# Note: Hugging Face TTS works without an API key for public models
VITE_HUGGINGFACE_API_KEY=your_huggingface_api_key_here_optional

# ElevenLabs TTS Configuration (Fallback)
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Development Configuration (optional)
# VITE_DEV_MODE=true